# Cloudflare configuration
# Create API token: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=cfut_...
CLOUDFLARE_ACCOUNT_ID=...

# Cloudflare Turnstile CAPTCHA
# Get these from: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=0x4AAAAAAA1LWBtap2vUCeCA  # Public key for forms
# TURNSTILE_SECRET_KEY is set via: npx wrangler secret put TURNSTILE_SECRET_KEY

# Google Sheets Integration (optional)
# Create a service account at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Share your Google Sheet with the service account email
# GOOGLE_SHEET_ID=1234567890abcdefg           # From spreadsheet URL
# GOOGLE_SERVICE_ACCOUNT_EMAIL=name@project.iam.gserviceaccount.com
# GOOGLE_SHEET_RANGE=A:E                       # Columns: Timestamp, Email, Name, Subject, Message
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY is set via: npx wrangler secret put GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY
