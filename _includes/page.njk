---
layout: base.njk
---
{% if page.url == '/contact/' %}
<script>
  // Set Turnstile site key from environment or .env
  window.TURNSTILE_SITE_KEY = '{{ site.turnstile.siteKey }}';
</script>
{% endif %}
<article class="page{% if page.url == '/books/' %} page--books{% endif %}">
  <h1 class="page-title">{{ title }}</h1>
  <div class="post-body">
    {% if page.url == '/contact/' %}
      <form id="contact-form" class="contact-form">
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required autocomplete="email">
        </div>

        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" autocomplete="name">
        </div>

        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject">
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6"></textarea>
        </div>

        <div class="turnstile-wrapper" id="turnstile-wrapper"></div>

        <button type="submit" class="submit-button">
          <span class="default">Send message</span>
        </button>
      </form>
    {% else %}
      {{ content | safe }}
    {% endif %}
  </div>
</article>
{% if page.url == '/contact/' %}
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js?onload=onloadTurnstileCallback" async defer></script>
<script src="/assets/js/turnstile-form.js"></script>
{% endif %}
